---
import Layout from '../layouts/Layout.astro';
---

<Layout title="cinema cabbage">
	<main>
		<iframe 
			class="youtube-iframe"
			src="https://www.youtube.com/embed/YdVkZHwPZHY?autoplay=0&rel=0" 
			title="YouTube video player" 
			allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
			allowfullscreen>
		</iframe>
	</main>
</Layout>

<style>
	main {
		width: 100vw;
		height: 100vh;
		background-color: #000000;
		display: flex;
		justify-content: center;
		align-items: center;
		overflow: hidden;
	}

	.youtube-iframe {
		width: 70%;
		height: 70%;
		border: none;
		transition: width 0.3s ease, height 0.3s ease;
	}

	@media (max-width: 768px) {
		.youtube-iframe {
			width: 90%;
			height: 50%;
		}
	}

	@media (max-width: 480px) {
		.youtube-iframe {
			width: 95%;
			height: 40%;
		}
	}
</style>
